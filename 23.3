import folium
from folium.plugins import HeatMap
from IPython.display import display

m = folium.Map(location=[10.7610, 106.6682], zoom_start=13)

heat_data = [
    [10.7674, 106.6762, 1.0],
    [10.7657, 106.6692, 0.85],
    [10.7595, 106.6667, 0.7],
    [10.7530, 106.6724, 0.6],
    [10.7488, 106.6704, 0.1]
]

HeatMap(heat_data).add_to(m)


legend = '''
<div style="position:fixed; bottom:50px; right:50px; background:white; padding:5px; z-index:1000">
🔴 Đỏ: Rất cao<br>
🟠 Cam: Cao<br>
🟡 Vàng: Trung bình<br>
🟢 Green: Trung bình thấp<br>
🔵 Xanh: Thấp
</div>
'''
m.get_root().html.add_child(folium.Element(legend))

print("🔴 Vùng đỏ: Tăng shipper, nhiều khuyến mãi")
print("🟠 Vùng cam: Duy trì dịch vụ")
print("🟡 Vùng vàng: Khảo sát thêm")
print("🟢 Xanh lá: Tiềm năng phát triển")
print("🔵 Xanh dương: Chưa cần đầu tư")

display(m)
